{
  "env": {
    "MCP_TOOL_TIMEOUT": "120000"
  },
  "permissions": {
    "allow": [
      "WebFetch(domain:github.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:npmjs.com)",
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:crates.io)",
      "WebFetch(domain:docs.rs)",
      "WebFetch(domain:developer.mozilla.org)",
      "WebFetch(domain:stackoverflow.com)",
      "WebFetch(domain:docs.python.org)",
      "WebFetch(domain:registry.npmjs.org)"
    ],
    "deny": [
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf /:*)",
      "Bash(rm -r ~:*)",
      "Bash(rm -r /:*)",
      "Bash(/bin/rm:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force:*)"
    ],
    "ask": [
      "Bash(sudo:*)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cmd=$(jq -r '.tool_input.command // \"\"'); echo \"$cmd\" | grep -qE '\\brm\\b' && echo 'CAUTION: Be careful with file deletion. Make sure you know exactly what you are deleting and why. If you are unsure, stop and ask rather than proceeding.' ; exit 0"
          },
          {
            "type": "command",
            "command": "cmd=$(jq -r '.tool_input.command // \"\"'); echo \"$cmd\" | grep -qE 'git\\s+push.+(-f|--force)' && echo 'BLOCKED: Force push is not allowed. It destroys git history and removes the ability to recover from mistakes. Use a different approach.' && exit 2; exit 0"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-command.sh"
  },
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true
  }
}
